# ═══════════════════════════════════════════════════════════════════
# gaet — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to ~/.gaet/.env and fill in your settings:
#
#   cp .env.example ~/.gaet/.env
#   nano ~/.gaet/.env
#
# MINIMUM required: GAET_REMOTE_URL
# Everything else has sensible defaults.
# ═══════════════════════════════════════════════════════════════════

# ─── Cloud Database (Required) ────────────────────────────────────
# PostgreSQL connection string to your cloud database (Supabase, Neon, RDS, etc.)
# Format: postgresql://user:password@host:5432/db
#
# GAET_REMOTE_URL=postgresql://user:password@host:5432/db
# ↑ Uncomment and fill with your cloud database URL

# ─── Local Database ───────────────────────────────────────────────
# PostgreSQL connection string for your local database
# Format: postgresql://user:password@host:5432/db
# Default: hindsight@127.0.0.1:5432/hindsight
#
# GAET_LOCAL_URL=postgresql://hindsight:hindsight@127.0.0.1:5432/hindsight

# ─── Backup & Retention ───────────────────────────────────────────
# How many days to keep old backup files
# GAET_RETENTION_DAYS=7
# Auto-backup interval in hours (used by push --auto)
# GAET_BACKUP_INTERVAL=6

# ─── Dashboard ────────────────────────────────────────────────────
# Port for the web dashboard (Next.js)
# GAET_DASHBOARD_PORT=9191
# Host to bind the dashboard (0.0.0.0 = all interfaces)
# GAET_DASHBOARD_HOST=0.0.0.0

# ─── Service Names ────────────────────────────────────────────────
# Prefix for systemd/launchd/schtasks service names
# GAET_SERVICE_PREFIX=gaet

# ─── Project Directory ────────────────────────────────────────────
# Override the project root path (for dashboard discovery)
# Only needed if gaet can't find the dashboard/ directory automatically
# GAET_PROJECT_DIR=/home/user/gaet

# ─── PostgreSQL Tools Paths ───────────────────────────────────────
# By default gaet auto-detects pg_dump, pg_restore, psql from PATH.
# To use specific versions, set them here.
# GAET_PG_DUMP=/usr/bin/pg_dump
# GAET_PG_RESTORE=/usr/bin/pg_restore
# GAET_PSQL=/usr/bin/psql

# ─── Custom Tables ────────────────────────────────────────────────
# If your database tables have non-default names, list them here
# (comma-separated)
# GAET_TABLES=memory_units,banks,chunks,entities,documents,async_operations,audit_log,file_storage,memory_links

# ─── SSL ──────────────────────────────────────────────────────────
# For cloud connections requiring SSL (Supabase requires this)
# GAET_REMOTE_SSLMODE=require
