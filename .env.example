# ═══════════════════════════════════════════════════════════════════
# gaet — Konfigurasi Lengkap
# ═══════════════════════════════════════════════════════════════════
# Cara pakai: copy file ini ke ~/.gaet/.env lalu isi sesuai kebutuhan
#
#   cp .env.example ~/.gaet/.env
#   nano ~/.gaet/.env
#
# Semua opsi ada di sini. Yang wajib diisi: GAET_REMOTE_URL
# Sisanya sudah punya nilai default yang masuk akal.
# ═══════════════════════════════════════════════════════════════════

# ─── Database Lokal ───────────────────────────────────────────────
# gaet backup database PostgreSQL lokal ke cloud. Isi koneksi DB-mu.
# Default: hindsight punya pg0 di localhost:5432

# GAET_LOCAL_DB_HOST=127.0.0.1
# GAET_LOCAL_DB_PORT=5432
# GAET_LOCAL_DB_USER=hindsight
# GAET_LOCAL_DB_NAME=hindsight
# GAET_LOCAL_DB_PASS=hindsight

# ─── Remote Database (Cloud Target) ───────────────────────────────
# WAJIB DIISI. Connection string ke database tujuan (Supabase, Neon, RDS, VPS, dll).
# Format: postgresql://user:pass@host:5432/db
#
# Cara dapat:
#   1. Buka https://supabase.com
#   2. Project → Settings → Database → Connection string
#   3. Pilih "URI" mode, copy
#
# GAET_REMOTE_URL=postgresql://user:password@host:5432/db
# ↑ Hapus tanda # dan isi dengan URL database tujuan-mu

# ─── Direktori ────────────────────────────────────────────────────
# GAET_CONFIG_DIR=${HOME}/.gaet
# GAET_BACKUP_DIR=${HOME}/.gaet/backups
# GAET_LOG_FILE=${GAET_BACKUP_DIR}/gaet.log
# GAET_CRON_LOG=${GAET_BACKUP_DIR}/cron.log

# ─── Backup & Retensi ─────────────────────────────────────────────
# Berapa lama backup lama disimpan (hari)
# GAET_RETENTION_DAYS=7
# Jadwal auto-backup (jam). Default: setiap 6 jam
# GAET_AUTO_INTERVAL=6

# ─── PostgreSQL Tools ─────────────────────────────────────────────
# Secara default gaet auto-detect pg_dump, pg_restore, psql dari PATH.
# Kalau mau pake versi tertentu, set di sini.
# GAET_PG_DUMP=/usr/bin/pg_dump
# GAET_PG_RESTORE=/usr/bin/pg_restore
# GAET_PSQL=/usr/bin/psql

# ─── Dashboard ────────────────────────────────────────────────────
# Port untuk dashboard web (Next.js)
# GAET_DASHBOARD_PORT=9191
# Host untuk dashboard (0.0.0.0 = semua interface)
# GAET_DASHBOARD_HOST=0.0.0.0

# ─── Advance: Kustomisasi Database ────────────────────────────────
# Kalau tabel-tabel Hindsight punya nama berbeda dari default,
# set di sini. Format: pisah dengan koma
# GAET_TABLES=memory_units,banks,chunks,entities,documents,async_operations,audit_log,file_storage,memory_links

# ─── Advance: SSL ─────────────────────────────────────────────────
# Kalau koneksi ke cloud butuh SSL (Supabase wajib require)
# GAET_REMOTE_SSLMODE=require

# ─── Advance: Systemd ────────────────────────────────────────────
# Nama unit systemd untuk auto-backup & dashboard
# GAET_SERVICE_PREFIX=gaet
